# Configuração de Exemplo — Production Environment
# Copie para terraform.tfvars e preencha com seus valores

# ============================================================================
# AWS ACADEMY / LEARNER LAB
# ============================================================================

# ARN do principal (usuário ou role) que criou o cluster
# Para descobrir: aws sts get-caller-identity
principal_arn = "arn:aws:iam::123456789012:user/awsstudent"

# ARN da LabRole (AWS Academy)
lab_role = "arn:aws:iam::123456789012:role/LabRole"

# ============================================================================
# GERAL
# ============================================================================

aws_region   = "us-east-1"
project_name = "framecast"
environment  = "production"

# ============================================================================
# EKS
# ============================================================================

eks_cluster_version = "1.31"
access_config       = "API_AND_CONFIG_MAP"
node_group          = "framecast"
instance_type       = "t3.medium"
node_desired_size   = 2
node_max_size       = 3
node_min_size       = 1

# ============================================================================
# S3
# ============================================================================

s3_bucket_raw           = "framecast-videos-raw"
s3_bucket_output        = "framecast-videos-output"
s3_multipart_abort_days = 3

# ============================================================================
# SES
# ============================================================================

ses_from_email = "noreply@framecast.app"
ses_domain     = ""   # Ex: "framecast.app" — requer registro DNS para verificação

# ============================================================================
# SQS
# ============================================================================

sqs_visibility_timeout = 900   # 15 min — deve cobrir lease + heartbeat do worker
sqs_max_receive_count  = 3
sqs_retention_seconds  = 1209600  # 14 dias

# ============================================================================
# CONTROLLERS HELM
# ============================================================================

enable_keda           = true
enable_metrics_server = true
enable_datadog_agent  = false   # true requer datadog_api_key

# ============================================================================
# FINOPS TAGS
# ============================================================================

cost_center   = "engineering"
business_unit = "technology"
owner         = "devops-team"
application   = "framecast"
microservice  = "shared"

# Opcional
# budget_code     = "FIAP-2025-001"
# expiration_date = "2025-12-31"

# ============================================================================
# DATADOG (OPCIONAL)
# ============================================================================

# datadog_api_key = "sua-api-key"
# datadog_app_key = "sua-app-key"
# enable_datadog_agent = true
