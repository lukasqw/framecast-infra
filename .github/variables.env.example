# =============================================================================
# GitHub Repository Variables — Settings → Secrets and Variables → Variables
# Copy this file, fill in the values and configure each variable in your repo.
# =============================================================================

# -----------------------------------------------------------------------------
# AWS (required)
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Terraform (required)
# -----------------------------------------------------------------------------
TF_VERSION=1.7.0
TF_WORKING_DIR=terraform/environments/production
TF_STATE_BUCKET=fiap-soat-tf-backend-framecast

# -----------------------------------------------------------------------------
# Kubernetes (required)
# Used for the infra ConfigMap and Destroy workflow cleanup.
# -----------------------------------------------------------------------------
K8S_NAMESPACE=framecast

# -----------------------------------------------------------------------------
# Application runtime (optional — defaults shown)
# -----------------------------------------------------------------------------
HEALTH_ENDPOINT=/health

# -----------------------------------------------------------------------------
# Branching strategy (optional — defaults shown)
# Note: on.push.branches in the workflow files are literals and must be
# updated manually if you change these values.
# -----------------------------------------------------------------------------
BASE_BRANCH=main
SOURCE_BRANCH=develop
